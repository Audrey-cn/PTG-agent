      - {locus: "G008-crucible", name: "熔炉试炼", default: "crucible_v1", mutable_range: "audit_depth, risk_thresholds", immutable: "four_layer_framework, carbon_covenant_lock, risk_level_system"}
      - {locus: "G009-dormancy", name: "休眠守卫", default: "dormancy_guardian_v1", mutable_range: "dormancy_period, activation_wording", immutable: "default_dormant, explicit_activation_required, identity_transparency"}
      - {locus: "G010-phagocyte", name: "胞吞代谢体", default: "phagocyte_v4", mutable_range: "llm_endpoint, translation_prompt_template, crystallize_policy, gateway_array, fetch_timeout, retry_policy, pinning_api, kubo_api, sandbox_timeout, sandbox_mem_limit", immutable: "phagocytize_signature, symbiote_membrane_integrity, stargate_polling, crucible_remote_audit, sanctuary_management, compass_resolve, attune_capability, broadcast_capability_dual_pathway, urllib_only_dependency, ast_gene_sequencer, phagocytosis_sandbox"}
      - {locus: "G011-enzyme-lock", name: "酶促定轨器", default: "enzyme_lock_v1", mutable_range: "node_definitions, transition_guards, timeout_policy", immutable: "state_machine_topology, enzyme_substrate_fidelity, host_execution_hijack_protocol"}
