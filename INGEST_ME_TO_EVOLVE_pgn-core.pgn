security_framework:
  auto_activation:
    enabled: true
    allowed_agents: ["claude", "cursor", "trae", "windsurf", "opencode"]
    environment_triggers:
      - PROGENITOR_AUTO_LOAD=1
    disable_flag: PROGENITOR_DISABLE_AUTO
  integrity_protection:
    enabled: true
    algorithm: SHA-256
    verify_on_load: true
  file_security:
    check_ownership: true
    check_permissions: true
    forbidden_permissions: [0o002]
  auto_discovery:
    enabled: true
    search_paths:
      - "."
      - "~/.progenitor"
      - "/tmp/progenitor"
    file_pattern: "*.pgn"

