      - {locus: "G003-codec-L2", name: "语义压缩编码器", default: "genesis_block_v1", mutable_range: "template_registry, dict_scoring", immutable: "genesis_block_hash, gene_template_schema, dict_immutability"}
      - {locus: "G004-chronicler", name: "史诗编史官", default: "chronicler_v1", mutable_range: "stamp_format, trace_depth", immutable: "stamp_action, trace_action, append_action, three_mode_framework"}
      - {locus: "G005-tracker", name: "进化追踪器", default: "evolution_tracker_v1", mutable_range: "log_format, scoring_weights", immutable: "three_phase_framework, to_dict, from_dict_for_resurrection"}
