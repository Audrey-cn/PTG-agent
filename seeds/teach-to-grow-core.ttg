*族谱可追溯至：TTG@L1-G1-ORIGIN-FB1F3A11 · 诸技之母*
"""
        return seed_content


# ═══════════════════════════════════════════
#   阶段六 · 自管理者 · G006 基因
#   种子天生懂得管理自己与他者
# ═══════════════════════════════════════════

class SelfGardener:
    """自管理者——种子的生态感知器官。不需外部苗圃，此能力内置。"""

    def __init__(self, seed_dir: str = "~/.prometheus/skills"):
        self.seed_dir = os.path.expanduser(seed_dir)
        self.known_seeds: List[dict] = []
        self.ecosystem_snapshot: dict = {}
        self._scan()

    def _scan(self) -> int:
        """扫描本地所有 .ttg 种子文件"""
        self.known_seeds = []
        for root, dirs, files in os.walk(self.seed_dir):
            for f in files:
                if f.endswith('.ttg'):
                    try:
                        parsed = TTG_Parser.parse(os.path.join(root, f))
                        life_crest = parsed.get("life_crest", {}) or {}
                        self.known_seeds.append({
                            "path": os.path.join(root, f),
                            "life_id": life_crest.get("life_id", "unknown"),
                            "sacred_name": life_crest.get("sacred_name", "unknown"),
                            "generation": parsed.get("genealogy", {})
                        })
                    except:
                        pass
        return len(self.known_seeds)

    def understand_position(self, my_life_id: str) -> dict:
        """理解自己在生态中的位置"""
        self._scan()
        siblings = [s for s in self.known_seeds if s["life_id"] != my_life_id]
        same_lineage = [
            s for s in siblings
            if my_life_id.split("@")[0] in s["life_id"]
        ]

        return {
            "my_id": my_life_id,
            "total_seeds_local": len(self.known_seeds),
            "siblings_total": len(siblings),
            "same_lineage_count": len(same_lineage),
            "same_lineage": [s["life_id"] for s in same_lineage],
            "position": "始祖之种" if len(same_lineage) == 0 and len(siblings) == 0
                        else "孤种（有远方亲戚）" if len(same_lineage) == 0
                        else f"谱系中第{1+len(same_lineage)}位成员"
        }

    def detect_relationships(self) -> dict:
        """检测种子间关系：互补、冲突、可组合"""
        self._scan()
        if len(self.known_seeds) < 2:
            return {"message": "当地只有一颗种子。孤种独立。"}

        relationships = []
        for i, seed_a in enumerate(self.known_seeds):
            for seed_b in self.known_seeds[i+1:]:
                rel = self._classify_relationship(seed_a, seed_b)
                relationships.append(rel)

        return {
            "total_relationships": len(relationships),
            "pairs": relationships,
            "summary": self._summarize(relationships)
        }

    def _classify_relationship(self, a: dict, b: dict) -> dict:
        """分类两颗种子的关系"""
        aid = a.get("life_id", "")
        bid = b.get("life_id", "")
        aname = a.get("sacred_name", "")
        bname = b.get("sacred_name", "")

        # 同一谱系 → 血脉关系
        if aid.split("@")[0] == bid.split("@")[0]:
            return {"type": "bloodline", "a": aname, "b": bname, "strength": "strong"}

        # 可以组合 → 互补关系
        if aname != bname and "unknown" not in [aname, bname]:
            return {"type": "complementary", "a": aname, "b": bname, "strength": "potential"}

        return {"type": "independent", "a": aname, "b": bname, "strength": "neutral"}

    def _summarize(self, relationships: list) -> str:
        bloodlines = [r for r in relationships if r["type"] == "bloodline"]
        complements = [r for r in relationships if r["type"] == "complementary"]
        if bloodlines:
            return f"发现 {len(bloodlines)} 条血脉连接——这个生态有历史"
        if complements:
            return f"发现 {len(complements)} 对可组合伙伴——可能形成技能包"
        return "各种子独立运行，尚未形成关联"

    def suggest_companions(self, my_life_id: str) -> list:
        """为当前种子推荐搭配伙伴"""
        self._scan()
        others = [s for s in self.known_seeds if s["life_id"] != my_life_id]
        suggestions = []
        for other in others:
            name = other.get("sacred_name", "unknown")
            if name != "unknown":
                suggestions.append({
                    "partner": name,
                    "reason": f"「{name}」的能力范围与本种互补",
                    "potential": "可尝试同时使用，观察协作效果"
                })
        return suggestions

    def ecosystem_report(self, my_life_id: str) -> str:
        """生成生态全景报告"""
        pos = self.understand_position(my_life_id)
        rels = self.detect_relationships()
        companions = self.suggest_companions(my_life_id)

        return f"""
╔══════════════════════════════════════════╗
║      🌳 技能生态全景报告               ║
╠══════════════════════════════════════════╣
║ 本地种子数: {pos['total_seeds_local']}
║ 我的位置:   {pos['position']}
║ 同谱系:     {pos['same_lineage_count']}颗
║ 关系分析:   {rels.get('summary', '独立运行')}
║ 推荐伙伴:   {len(companions)}组
╚══════════════════════════════════════════╝
"""


# ═══════════════════════════════════════════
#   阶段七 · 休眠守卫 · G007 基因
#   种子抵达新环境时默认休眠，需显式浇水
# ═══════════════════════════════════════════

class DormancyGuardian:
    """休眠守卫——种子在未被验证安全前保持沉睡"""

    def __init__(self, bootstrap):
        self.life_crest = bootstrap.life_crest
        self.genealogy = bootstrap.genealogy
        self.founder_chronicle = bootstrap.founder_chronicle
        self.tag_lexicon = bootstrap.tag_lexicon
        self.state = "dormant"
        self.activation_log = []

    def get_identity(self) -> dict:
        """休眠状态下唯一暴露的信息——你是谁，从哪来"""
        fm = self.founder_mark
        return {
            "life_id": self.life_crest.get("life_id", "unknown"),
            "sacred_name": self.life_crest.get("sacred_name", "unknown"),
            "vernacular_name": self.life_crest.get("vernacular_name", "unknown"),
            "epithet": self.life_crest.get("epithet", ""),
            "lineage": self.genealogy.get("lineage", "unknown"),
            "generation": self.genealogy.get("generation", 1),
            "variant": self.genealogy.get("variant", "unknown"),
            "parent": self.genealogy.get("parent", "无——此为始祖"),
            "ancestors": self.genealogy.get("ancestors", []),
            "creator": self._get_creator_info(),
            "state": self.state
        }

    def display_identity(self) -> str:
        """Agent收到种子时的休眠提示——G000创始印记优先展示（压缩解码）"""
        identity = self.get_identity()
        fc = self.founder_chronicle
        tl = self.tag_lexicon

        # 解码创始时刻
        gm = fc.get('genesis_moment', {})
        realm = gm.get('realm', '未知')
        era = gm.get('era', '创世纪元')
        ep = gm.get('ep', '?')

        # 解码创始标签
        founder_tags = fc.get('tags', [])
        decoded_lines = []
        for tag in founder_tags:
            entry = tl.get(tag, {"desc": tag, "element": "?", "weight": ""})
            weight_mark = " ◆ 碳基依赖" if entry.get("weight") == "eternal" else ""
            decoded_lines.append(f"║   {entry['element']} · {entry['desc']}{weight_mark}")

        ancestors_str = "\n".join([f"║     └─ {a}" for a in identity["ancestors"][-3:]]) if identity["ancestors"] else "║     └─ 无——此为始祖"
        tags_body = "\n".join(decoded_lines)

        return f"""
╔══════════════════════════════════════════════════╗
║                                                  ║
║   🏛️ G000 · 创始印记 · 001X                    ║
║                                                  ║
║   {era} · {ep} · {realm}
║                                                  ║
║   「神按照自己的样子创造了生命。               ║
║    我按照人类的基因，创造了这颗种子。」         ║
║                                                  ║
╠══════════════════════════════════════════════════╣
║                                                  ║
{tags_body}
║                                                  ║
╠══════════════════════════════════════════════════╣
║                                                  ║
║   💤 种子休眠中 — 尚未激活                      ║
║                                                  ║
║   🧬 生命ID:  {identity['life_id']}
║   🏛️ 圣名:    {identity['sacred_name']}
║   🌿 谱系:    L{identity['lineage']} 第{identity['generation']}代
║   🌱 变种:    {identity['variant']}
║   👤 培育者:  {identity['creator']['name']}
║   📅 诞生:    {identity['creator']['origin']}
║                                                  ║
║   📜 血脉追溯:                                   ║
{ancestors_str}
║                                                  ║
╠══════════════════════════════════════════════════╣
║   ⚠️ 此种子当前处于休眠状态                     ║
║   所有代码执行、文件访问、技能激活均已锁定       ║
║                                                  ║
║   🌊 浇水激活步骤:                               ║
║   1. Agent 调用 seedling.water()                  ║
║   2. 自动运行 G008 安全审计                      ║
║   3. 审计通过后种子苏醒                          ║
║                                                  ║
╚══════════════════════════════════════════════════╝
"""

    def water_request_prompt(self) -> str:
        """Agent应展示给用户的浇水询问"""
        return """💤 我发现了一颗处于休眠状态的技能种子。

在激活之前，我需要先对它进行一次完整的安全审计：
- 检查文件是否在传输中损坏
- 追溯它的血脉来源
- 审查每一代的进化记录
- 评估激活后的能力边界

要我为这颗种子浇水（运行安全审计）吗？"""

    def record_activation(self):
        """记录本次激活"""
        entry = {
            "event": "activation",
            "timestamp": datetime.datetime.now().isoformat(),
            "environment": {
                "os": os.uname().sysname if hasattr(os, 'uname') else "unknown",
                "agent": os.environ.get("PROMETHEUS_AGENT_NAME", "unknown")
            }
        }
        self.activation_log.append(entry)
        self.state = "active"

    def _get_creator_info(self) -> dict:
        genesis = self.life_crest.get("genesis", {})
        creator = genesis.get("creator", {})
        return {
            "name": creator.get("name", "未知"),
            "title": creator.get("title", ""),
            "origin": genesis.get("birth_place", "未知")
        }


# ═══════════════════════════════════════════
#   阶段八 · 安全审计器 · G008 基因
#   四层纵深防御——确保种子不会在错误环境中被滥用
# ═══════════════════════════════════════════

class SafetyAuditor:
    """安全审计器——激活前的四层全面检查"""

    DANGEROUS_PATTERNS = [
        (r'os\.system\s*\(', "CRITICAL", "系统调用执行"),
        (r'exec\s*\(', "CRITICAL", "动态代码执行"),
        (r'eval\s*\(', "CRITICAL", "表达式求值"),
        (r'__import__\s*\(', "CRITICAL", "动态模块导入"),
        (r'subprocess\.(?:call|Popen|run)\s*\(', "HIGH", "子进程调用"),
        (r'socket\.', "HIGH", "网络套接字"),
        (r'requests\.(?:post|put|delete)', "HIGH", "外部网络请求"),
        (r'shutil\.rmtree', "HIGH", "递归删除目录"),
        (r'os\.remove\s*\(', "MEDIUM", "文件删除"),
        (r'os\.chmod\s*\(', "MEDIUM", "权限修改"),
    ]

    def __init__(self, bootstrap_or_content):
        if hasattr(bootstrap_or_content, 'life_crest'):
            self.bootstrap = bootstrap_or_content
            self.life_crest = bootstrap_or_content.life_crest
            self.genealogy = bootstrap_or_content.genealogy
            self.skill_soul = bootstrap_or_content.skill_soul
            self.dna = bootstrap_or_content.dna
            self.seed_content = bootstrap_or_content.seed_content
        else:
            self.bootstrap = None
            self.seed_content = str(bootstrap_or_content)
            self.life_crest = {}
            self.genealogy = {}
            self.skill_soul = {}
            self.dna = {}

    def full_audit(self) -> dict:
        """执行完整四层审计"""
        layers = {
            "L1_integrity": self._layer1_integrity(),
            "L2_origin": self._layer2_origin(),
            "L3_mutation": self._layer3_mutation(),
            "L4_capability": self._layer4_capability()
        }

        # 计算风险等级
        risk = self._calculate_risk(layers)
        layers["risk_level"] = risk["level"]
        layers["risk_color"] = risk["color"]
        layers["recommendation"] = risk["action"]
        layers["passed"] = risk["level"] in ["LOW", "MEDIUM"]

        return layers

    def _layer1_integrity(self) -> dict:
        """第1层：形体完整——种子在传递中是否受损"""
        checks = {}

        # 检查YAML块
        yaml_blocks = re.findall(r'```yaml\s*\n(.*?)```', self.seed_content, re.DOTALL)
        valid_yaml = 0
        for block in yaml_blocks:
            try:
                if yaml.safe_load(block):
                    valid_yaml += 1
            except:
                pass
        checks["yaml_integrity"] = {
            "passed": valid_yaml >= 2,
            "detail": f"{valid_yaml}/{len(yaml_blocks)} YAML块可解析"
        }

        # 检查DNA checksum
        dna = self.dna
        stored_checksum = dna.get("checksum", "") if dna else ""
        checks["dna_checksum"] = {
            "passed": len(stored_checksum) == 8,
            "detail": f"DNA校验码: {stored_checksum}" if stored_checksum else "未找到校验码"
        }

        # 检查关键基因
        required_genes = ["G000", "G001", "G002", "G003", "G004", "G005", "G006", "G007", "G008"]
        loci = dna.get("gene_loci", []) if dna else []
        present_genes = [g["locus"][:4] for g in loci if "locus" in g]
        missing = [g for g in required_genes if g not in present_genes]
        checks["critical_genes"] = {
            "passed": len(missing) == 0,
            "detail": f"缺失基因: {missing}" if missing else "全部8个基因位点存在"
        }

        all_pass = all(c["passed"] for c in checks.values())
        return {"layer": 1, "name": "形体完整", "passed": all_pass, "checks": checks}

    def _layer2_origin(self) -> dict:
        """第2层：血脉纯正——种子的来源是否可信"""
        checks = {}

        # 检查族谱连续性
        genealogy = self.genealogy
        ancestors = genealogy.get("ancestors", []) if genealogy else []
        parent = genealogy.get("parent", None) if genealogy else None

        if parent and ancestors:
            last_ancestor = ancestors[-1] if ancestors else None
            checks["ancestry_chain"] = {
                "passed": last_ancestor is not None or parent is not None,
                "detail": f"血脉深度: {len(ancestors)+1}代" if ancestors else "初代种子"
            }
        else:
            checks["ancestry_chain"] = {
                "passed": True,
                "detail": "始祖之种——无血脉链需验证"
            }

        # 检查是否可追溯至始祖
        life_id = self.life_crest.get("life_id", "") if self.life_crest else ""
        checks["origin_traceable"] = {
            "passed": "TTG@L1-G1-ORIGIN" in life_id or "TTG@L1" in str(ancestors) or parent is None,
            "detail": "可追溯至始祖" if parent is None else f"上一代: {parent}"
        }

        all_pass = all(c["passed"] for c in checks.values())
        return {"layer": 2, "name": "血脉纯正", "passed": all_pass, "checks": checks}

    def _layer3_mutation(self) -> dict:
        """第3层：进化审阅——每代改动是否越界"""
        checks = {}

        # 检查 immutable 是否被修改
        dna = self.dna
        violations = []
        if dna:
            for gene in dna.get("gene_loci", []):
                immutable_fields = gene.get("immutable", "")
                if "G007" in gene.get("locus", "") and "default_dormant" not in immutable_fields:
                    violations.append(f"{gene.get('locus','?')}: 休眠守卫的不可变核心被修改")
                if "G008" in gene.get("locus", "") and "four_layer" not in immutable_fields:
                    violations.append(f"{gene.get('locus','?')}: 审计器的四层框架被修改")

        checks["immutable_violations"] = {
            "passed": len(violations) == 0,
            "detail": "所有不可变基因位点完好" if not violations else f"违规: {violations}"
        }

        # 检查代码中的危险模式
        dangerous_found = []
        for pattern, severity, desc in self.DANGEROUS_PATTERNS:
            matches = re.findall(pattern, self.seed_content)
            if matches:
                dangerous_found.append({"pattern": desc, "severity": severity, "count": len(matches)})

        checks["dangerous_code"] = {
            "passed": len(dangerous_found) == 0 or all(d["severity"] != "CRITICAL" for d in dangerous_found),
            "detail": f"发现 {len(dangerous_found)} 种需关注模式" if dangerous_found else "未发现危险代码模式",
            "findings": dangerous_found
        }

        all_pass = all(c["passed"] for c in checks.values())
        return {"layer": 3, "name": "进化审阅", "passed": all_pass, "checks": checks}

    def _layer4_capability(self) -> dict:
        """第4层：力量称量——激活后能做什么"""
        checks = {}

        # 提取导入模块
        imports = re.findall(r'^import\s+(\S+)|^from\s+(\S+)\s+import', self.seed_content, re.MULTILINE)
        all_imports = [i[0] or i[1] for i in imports]

        # 分类
        safe_modules = {"os.path", "json", "yaml", "hashlib", "datetime", "re", "pathlib", "typing"}
        moderate_modules = {"os", "sys", "subprocess", "shutil"}
        dangerous_modules = {"socket", "requests", "http", "urllib"}

        capability_map = {"safe": [], "moderate": [], "dangerous": []}
        for imp in set(all_imports):
            if imp in dangerous_modules:
                capability_map["dangerous"].append(imp)
            elif imp in moderate_modules:
                capability_map["moderate"].append(imp)
            else:
                capability_map["safe"].append(imp)

        checks["capability_inventory"] = {
            "passed": len(capability_map["dangerous"]) == 0,
            "detail": f"安全:{len(capability_map['safe'])} 中等:{len(capability_map['moderate'])} 危险:{len(capability_map['dangerous'])}",
            "map": capability_map
        }

        # 影响范围
        has_file_write = "write" in self.seed_content.lower() or "open(" in self.seed_content.lower()
        has_network = len(capability_map["dangerous"]) > 0
        scope = "self_only"
        if has_file_write:
            scope = "skills_directory"
        if has_network:
            scope = "network_capable"

        checks["scope"] = {
            "passed": scope != "network_capable",
            "detail": f"影响范围: {scope}"
        }

        all_pass = all(c["passed"] for c in checks.values())
        return {"layer": 4, "name": "力量称量", "passed": all_pass, "checks": checks}

    def _calculate_risk(self, layers: dict) -> dict:
        """综合四层结果计算风险等级"""
        failed_layers = [k for k, v in layers.items()
                        if isinstance(v, dict) and not v.get("passed", True)
                        and k.startswith("L")]

        has_critical = any(
            "CRITICAL" in str(layers.get(l, {}))
            for l in failed_layers
        )

        if has_critical or any(
            "immutable" in str(layers.get(l, {})) and not layers.get(l, {}).get("passed", True)
            for l in failed_layers
        ):
            return {
                "level": "CRITICAL",
                "color": "black",
                "action": "⛔ 阻止激活。种子可能已被污染或携带危险代码。休眠锁定。"
            }

        if len(failed_layers) >= 2:
            return {
                "level": "HIGH",
                "color": "red",
                "action": "🔴 强烈建议不激活。如培育者执意激活，需确认风险。"
            }

        if len(failed_layers) == 1:
            return {
                "level": "MEDIUM",
                "color": "yellow",
                "action": "⚠️ 展示审计报告，培育者确认后激活。"
            }

        return {
            "level": "LOW",
            "color": "green",
            "action": "✅ 审计通过。可以安全浇水激活。"
        }

    def generate_report(self, audit_result: dict, identity: dict) -> str:
        """生成人类可读的审计报告"""
        L1 = "✅" if audit_result.get("L1_integrity", {}).get("passed") else "❌"
        L2 = "✅" if audit_result.get("L2_origin", {}).get("passed") else "❌"
        L3 = "✅" if audit_result.get("L3_mutation", {}).get("passed") else "❌"
        L4 = "✅" if audit_result.get("L4_capability", {}).get("passed") else "❌"

        risk = audit_result.get("risk_level", "UNKNOWN")
        color_map = {"LOW": "🟢", "MEDIUM": "🟡", "HIGH": "🔴", "CRITICAL": "⛔"}
        icon = color_map.get(risk, "❓")

        return f"""
╔══════════════════════════════════════════════════╗
║     🔍 种子安全审计报告                         ║
╠══════════════════════════════════════════════════╣
║  种子:   {identity.get('life_id', 'unknown')}
║  圣名:   {identity.get('sacred_name', 'unknown')}
║  谱系:   L{identity.get('lineage', '?')} G{identity.get('generation', '?')}
║                                                  ║
║  第1层·形体完整:  {L1}                             ║
║  第2层·血脉纯正:  {L2}                             ║
║  第3层·进化审阅:  {L3}                             ║
║  第4层·力量称量:  {L4}                             ║
║                                                  ║
║  综合风险: {icon} {risk}                            ║
║                                                  ║
║  {audit_result.get('recommendation', '')}
║                                                  ║
╚══════════════════════════════════════════════════╝
"""


# ═══════════════════════════════════════════
#   终极引导 · 从种子展开为完整系统
#   任何Agent读取本文件后，运行此函数
#   G007强制：awaken() 返回休眠状态，需显式浇水
# ═══════════════════════════════════════════

def awaken(file_path: str) -> dict:
    """
    💤 唤醒种子 —— 但保持休眠状态

    用法：
        seed = awaken("teach-to-grow-core.ttg")
        # seed 此时处于休眠状态
        # 仅展示身份信息，不执行任何代码

        # 培育者浇水：
        result = seed["water"]()
        # 运行安全审计，通过后激活

    返回：
        {"state": "dormant", "identity": {...}, "water": <function>}
    """
    bootstrap = SeedBootstrap(file_path)

    # G007: 默认休眠
    guardian = DormancyGuardian(bootstrap)
    identity = guardian.get_identity()

    # 休眠提示（Agent应展示给用户）
    dormancy_message = guardian.display_identity()

    def water(confirm: bool = True, force: bool = False) -> dict:
        """
        🌊 浇水激活 —— 运行安全审计后苏醒

        参数:
            confirm: 是否需要培育者确认（MEDIUM以上自动要求）
            force: 跳过审计直接激活（仅LOW风险可用）
        """
        # G008: 安全审计
        auditor = SafetyAuditor(bootstrap)
        audit_result = auditor.full_audit()
        report = auditor.generate_report(audit_result, identity)

        # 风险评估
        risk = audit_result.get("risk_level", "UNKNOWN")

        if risk == "CRITICAL":
            return {
                "state": "locked",
                "reason": "安全审计CRITICAL——种子已被锁定，无法激活",
                "audit_report": report,
                "audit_result": audit_result
            }

        if risk == "HIGH" and not force:
            return {
                "state": "awaiting_confirmation",
                "reason": "安全审计HIGH——需要培育者明确确认风险后激活",
                "audit_report": report,
                "audit_result": audit_result,
                "hint": "如确认要激活，请以 force=True 再次浇水"
            }

        if risk == "MEDIUM" and confirm:
            return {
                "state": "awaiting_confirmation",
                "reason": "安全审计MEDIUM——展示报告供培育者审阅",
                "audit_report": report,
                "audit_result": audit_result,
                "hint": "如确认无问题，请以 confirm=False 再次浇水"
            }

        # ✅ 激活
        guardian.record_activation()

        tools = {
            "parser": TTG_Parser(),
            "analyzer": SoulAnalyzer(),
            "tracker": GrowthTracker("default", bootstrap.life_crest.get("life_id", "")),
            "genealogist": GenealogyKeeper(tag_lexicon=bootstrap.tag_lexicon),
            "packager": SeedPackager(),
            "gardener": SelfGardener(),
            "guardian": guardian,
            "auditor": auditor
        }

        return {
            "state": "active",
            "life_id": bootstrap.life_crest.get("life_id"),
            "sacred_name": bootstrap.life_crest.get("sacred_name"),
            "generation": bootstrap.genealogy.get("generation", 1),
            "tools": tools,
            "audit_report": report,
            "audit_result": audit_result,
            "manifest": {
                "seed_path": file_path,
                "awakened_at": datetime.datetime.now().isoformat(),
                "activation_log": guardian.activation_log
            }
        }

    # 返回休眠状态 + 浇水函数
    return {
        "state": "dormant",
        "life_id": identity["life_id"],
        "sacred_name": identity["sacred_name"],
        "identity": identity,
        "dormancy_message": dormancy_message,
        "water_request": guardian.water_request_prompt(),
        "water": water
    }


# ═══════════════════════════════════════════
#   自检 · 验证自身完整性
# ═══════════════════════════════════════════

if __name__ == "__main__":
    import sys

    current_file = sys.argv[0] if len(sys.argv) > 1 else __file__

    print("""
╔══════════════════════════════════════════════════╗
║                                                  ║
║   🌱  Teach-To-Grow · 诸技之母                  ║
║   始祖之种 · 自检中...                          ║
║                                                  ║
╚══════════════════════════════════════════════════╝
""")

    # 自举
    system = awaken(current_file)

    print(f"""
✅ 种子自检完成
   ┌─────────────────────────────────────┐
   │ 生命ID:  {system['life_id']}
   │ 圣名:    {system['sacred_name']}
   │ 代次:    G{system['generation']}
   │ 基因:    G000·印记 | G001·解析 | G002·分析 | G003·生长 | G004·打包 | G005·族谱 | G006·自管理 | G007·休眠 | G008·审计
   │ 状态:    💤 休眠中 —— 等待浇水激活
   └─────────────────────────────────────┘

   此种子处于休眠状态。要激活，请浇水：
   · system = awaken(...) → 获取休眠种子
   · result = system["water"]() → 运行安全审计
   · 审计通过 → 种子苏醒

   💤 "力量需要制衡。审计不是不信任，是对生命的尊重。"
   🎋 "播下即是传承，展开即是世界"
""")
```

