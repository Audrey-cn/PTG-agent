      description: "{evolution_entry.get('description', '本地化适应')}"
      innovations: {json.dumps([i.get('name', '') for i in innovations], ensure_ascii=False)}
      caretaker: "{creator}"
      growth_score: {growth_score.get('score', 0)}

transmission_chronicle:
  - transmission_id: "TX-BIRTH-{new_genealogy['generation']}"
    sequence: 0
    event: "变种诞生"
    from: "{parent_life_id}"
    to: "{creator}"
    timestamp: "{datetime.datetime.now().isoformat()}"
    environment: "由培育者环境自然决定"
    omen: "自父种传承而来，添本地之魂"
```

