      description: "记录三阶段培育过程，生成生长日志和健康报告"
      immutable: true
    - name: "种子打包"
      description: "将本地化技能打包为新一代 .ttg 种子，自动更新族谱"
      immutable: true
    - name: "族谱管理"
      description: "追踪谱系分叉、记录进化历程、可视化家族树"
      immutable: true

  # ── 核心原则（必须遵守） ──
  core_principles:
    - id: "P1"
      name: "灵魂优先"
      description: "任何本地化不得改变技能的核心原则和使命"
      test: "对比本地版本与原版的core_principles，相似度必须 > 80%"

    - id: "P2"
      name: "族谱不可断"
      description: "每次传递必须记录，每代进化必须入谱"
      test: "检查 transmission_chronicle 是否连续完整"

    - id: "P3"
      name: "生长需证"
      description: "任何声称的改进必须附带验证数据"
      test: "evolution_chronicle 中每条记录必须有 innovations 字段"

    - id: "P4"
      name: "自由在形"
      description: "鼓励本地创新，但不强制。技能可以只是简单使用"
      test: "不惩罚无创新的培育者"

    - id: "P5"
      name: "万物归宗"
      description: "所有谱系分支最终可追溯至始祖"
