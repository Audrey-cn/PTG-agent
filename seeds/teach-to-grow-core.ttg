## 🌿 第二章 · 生长法则 · 三阶段培育之道

> *"生根者存，发芽者盛，开花者传。培育非一日之功，乃终身之约。"*

```python
# ========================================
#   生长法则执行引擎
#   此代码即为框架本身——种子展开后即成系统
# ========================================

import os
import json
import yaml
import hashlib
import datetime
from pathlib import Path
from typing import Dict, List, Optional, Any

# ═══════════════════════════════════════════
#   阶段零 · 种子自举
#   当Agent读取本文件时，首先执行此段
# ═══════════════════════════════════════════

class SeedBootstrap:
    """种子自举引擎——从种子展开为完整系统"""

    def __init__(self, seed_path: str):
        self.seed_path = seed_path
        self.seed_content = self._read_seed()
        self.life_crest = self._extract_life_crest()
        self.genealogy = self._extract_genealogy()
        self.skill_soul = self._extract_soul()
        self.dna = self._extract_dna()
        self.tag_lexicon = self._extract_tag_lexicon()
        self.founder_chronicle = self.life_crest.get('founder_chronicle', {})

        print(f"""
╔══════════════════════════════════════════╗
║     🌱 种子自举完成 · 系统已展开       ║
║                                        ║
║  生命ID: {self.life_crest.get('life_id', '未知')}
║  圣名:   {self.life_crest.get('sacred_name', '未知')}
║  谱系:   {self.genealogy.get('lineage', '未知')}-G{self.genealogy.get('generation', '?')}
║  能力:   解析 · 分析 · 生长 · 打包 · 族谱
║                                        ║
║  "播下即是传承，展开即是世界"          ║
╚══════════════════════════════════════════╝
""")

    def _read_seed(self) -> str:
        with open(self.seed_path, 'r', encoding='utf-8') as f:
            return f.read()

    def _extract_yaml_block(self, content: str, marker: str) -> dict:
        """从Markdown中提取YAML代码块"""
        import re
        pattern = rf'```yaml\s*\n(.*?)```'
        blocks = re.findall(pattern, content, re.DOTALL)
        for block in blocks:
            if marker in block:
                return yaml.safe_load(block)
        return {}

    def _extract_life_crest(self) -> dict:
        return self._extract_yaml_block(self.seed_content, 'life_crest')

    def _extract_genealogy(self) -> dict:
        crest = self.life_crest
        return crest.get('genealogy_codex', {}).get('current_genealogy', {})

    def _extract_soul(self) -> dict:
        return self._extract_yaml_block(self.seed_content, 'skill_soul')

    def _extract_dna(self) -> dict:
        soul = self.skill_soul
        return soul.get('dna_encoding', {})

    def _extract_tag_lexicon(self) -> dict:
        """从genealogy_codex提取标签解码词典"""
        # geneaology_codex在life_crest的同级YAML块中
        import re
        yb = re.findall(r'```yaml\s*\n(.*?)```', self.seed_content, re.DOTALL)
        for block in yb:
            try:
                parsed = yaml.safe_load(block)
                if parsed and isinstance(parsed, dict) and 'genealogy_codex' in parsed:
                    gx = parsed['genealogy_codex']
                    return gx.get('tag_lexicon', {})
            except:
                pass
        return {}

    def get_full_capability(self) -> dict:
        """返回种子的全部可执行能力"""
        return {
            "parse_ttg": True,
            "analyze_skill": self.skill_soul.get('core_capabilities', []),
            "track_growth": True,
            "package_seed": True,
            "manage_genealogy": True,
            "life_id": self.life_crest.get('life_id'),
            "version": self.dna.get('version', '1.0')
        }


# ═══════════════════════════════════════════
#   阶段一 · 种子解析器
#   读取任何.ttg文件，展开为可操作对象
# ═══════════════════════════════════════════

class TTG_Parser:
    """.ttg 种子文件解析器——读懂每一粒种子的生命"""

    @staticmethod
    def parse(file_path: str) -> dict:
        """
        解析 .ttg 文件，返回完整的生命信息
        输入：.ttg 文件路径
        输出：结构化的种子对象
        """
        with open(file_path, 'r', encoding='utf-8') as f:
            content = f.read()

        return {
            "file_path": file_path,
            "life_crest": TTG_Parser._extract_section(content, 'life_crest'),
            "genealogy": TTG_Parser._extract_section(content, 'genealogy_codex'),
            "skill_soul": TTG_Parser._extract_section(content, 'skill_soul'),
            "dna": TTG_Parser._extract_section(content, 'dna_encoding'),
            "transmissions": TTG_Parser._extract_section(content, 'transmission_chronicle'),
            "evolution": TTG_Parser._extract_section(content, 'evolution_chronicle'),
            "raw_size": len(content),
            "parsed_at": datetime.datetime.now().isoformat()
        }

    @staticmethod
    def _extract_section(content: str, section_name: str) -> Optional[dict]:
        """从Markdown中提取特定YAML区块"""
        import re
        # 查找包含section_name的yaml代码块
        pattern = rf'```yaml\s*\n(.*?)```'
        blocks = re.findall(pattern, content, re.DOTALL)
        for block in blocks:
            try:
                parsed = yaml.safe_load(block)
                if parsed and section_name in json.dumps(parsed, default=str):
                    # 递归查找
                    result = TTG_Parser._find_key(parsed, section_name)
                    if result:
                        return result
            except:
                continue
        return None

    @staticmethod
    def _find_key(data, key):
        """递归查找嵌套字典中的key"""
        if isinstance(data, dict):
            if key in data:
                return data[key]
            for v in data.values():
                result = TTG_Parser._find_key(v, key)
                if result:
                    return result
        return None

    @staticmethod
    def validate(parsed: dict) -> dict:
        """验证种子的完整性"""
        checks = {
            "has_life_crest": parsed.get("life_crest") is not None,
            "has_genealogy": parsed.get("genealogy") is not None,
            "has_soul": parsed.get("skill_soul") is not None,
            "has_life_id": False,
            "file_size_ok": parsed.get("raw_size", 0) > 100
        }

        life_crest = parsed.get("life_crest", {})
        if life_crest:
            checks["has_life_id"] = "life_id" in str(life_crest)

        checks["is_valid"] = all(checks.values())
        return checks


# ═══════════════════════════════════════════
#   阶段二 · 技能灵魂分析器
#   从任何技能中提取不可变的核心
# ═══════════════════════════════════════════

class SoulAnalyzer:
    """技能灵魂分析器——看见每个技能的本质"""

    @staticmethod
    def analyze(skill_content: str, skill_name: str = "unknown") -> dict:
        """
        分析技能内容，提取灵魂
        这是将普通SKILL.md转化为种子灵魂的关键
        """
        principles = SoulAnalyzer._extract_principles(skill_content)
        taboos = SoulAnalyzer._extract_taboos(skill_content)
        essence = SoulAnalyzer._sense_essence(skill_content, skill_name)

        return {
            "skill_name": skill_name,
            "core_principles": principles,
            "taboos": taboos,
            "essence": essence,
            "analyzed_at": datetime.datetime.now().isoformat()
        }

    @staticmethod
    def _extract_principles(content: str) -> List[dict]:
        """提取核心原则"""
        principles = []
        keyword_patterns = [
            (r'(?:核心|必须|一定|务必|永远|始终)(?:要|需要|应该)?[：:]\s*(.+?)(?:\n|$)', 'directive'),
            (r'(?:原则|规则|信条)\d*[：:]\s*(.+?)(?:\n|$)', 'principle'),
            (r'##\s*(?:核心|原则|规范|准则)[^\n]*\n(.+?)(?=\n##|\Z)', 'section'),
        ]

        import re
        for pattern, ptype in keyword_patterns:
            matches = re.findall(pattern, content, re.DOTALL | re.IGNORECASE)
            for i, match in enumerate(matches):
                principles.append({
                    "id": f"AUTO-P{i+1}",
                    "name": match.strip()[:80],
                    "source": ptype,
                    "immutable": True
                })

        return principles[:10]  # 最多10条

    @staticmethod
    def _extract_taboos(content: str) -> List[str]:
        """提取禁忌"""
        import re
        taboos = []
        patterns = [
            r'[❌🚫⛔⚠️](.+?)(?:\n|$)',
            r'(?:不要|禁止|绝不|不可|严禁)[：:]*\s*(.+?)(?:\n|$)',
            r'禁忌[：:]\s*(.+?)(?:\n|$)',
        ]
        for pattern in patterns:
            matches = re.findall(pattern, content, re.IGNORECASE)
            taboos.extend([f"❌ {m.strip()[:80]}" for m in matches])

        return list(set(taboos))[:8]

    @staticmethod
    def _sense_essence(content: str, skill_name: str) -> dict:
        """感知技能的气质"""
        # 分析语言风格来判断气质
        formal_score = content.count('请') + content.count('您')
        casual_score = content.count('直接') + content.count('就行')
        poetic_score = content.count('如') + content.count('若')

        if poetic_score > formal_score and poetic_score > casual_score:
            vibe = "诗意引导者"
        elif casual_score > formal_score:
            vibe = "亲切伙伴"
        else:
            vibe = "严谨导师"

        return {
            "vibe": vibe,
            "tone": "由内容自然感知",
            "role": "由功能自然推导"
        }


# ═══════════════════════════════════════════
#   阶段三 · 生长追踪器
#   记录技能从种子到大树的全过程
# ═══════════════════════════════════════════

class GrowthTracker:
    """生长追踪器——见证每一株技能生命的成长"""

    def __init__(self, skill_name: str, life_id: str, log_dir: str = "~/.prometheus/seedling-logs"):
        self.skill_name = skill_name
        self.life_id = life_id
        self.log_dir = os.path.expanduser(log_dir)
        self.current_phase = "rooting"  # rooting → sprouting → blooming
        self.phase_start_dates = {"rooting": datetime.datetime.now().isoformat()}
        os.makedirs(self.log_dir, exist_ok=True)

        print(f"""
╔══════════════════════════════════════════╗
║       🌿 生长追踪器已启动              ║
║   技能: {skill_name}
║   生命ID: {life_id}
║   日志: {self.log_dir}
╚══════════════════════════════════════════╝
""")

    def log_usage(self, context: str, felt_good: List[str] = None,
                  felt_awkward: List[str] = None, wish_for: List[str] = None,
                  satisfaction: int = 5) -> dict:
        """记录一次使用体验"""
        entry = {
            "date": datetime.datetime.now().strftime("%Y-%m-%d %H:%M"),
            "phase": self.current_phase,
            "usage_context": context,
            "felt_good": felt_good or [],
            "felt_awkward": felt_awkward or [],
            "wish_for": wish_for or [],
            "satisfaction": satisfaction,
            "aha_moments": []
        }

        self._save_entry(entry)
        self._check_phase_transition()
        return entry

    def log_innovation(self, name: str, reason: str,
                       implementation: str, effect: str) -> dict:
        """记录一项创新"""
        innovation = {
            "id": self._generate_innovation_id(),
            "name": name,
            "reason": reason,
            "implementation": implementation,
            "effect": effect,
            "date": datetime.datetime.now().isoformat(),
            "phase": self.current_phase
        }
        self._save_innovation(innovation)
        return innovation

    def calculate_growth_score(self) -> dict:
        """计算当前生长分数"""
        logs = self._load_logs()

        if not logs:
            return {"score": 0, "phase": self.current_phase, "message": "尚未有使用记录"}

        avg_satisfaction = sum(l.get("satisfaction", 5) for l in logs) / len(logs)
        adaptation_ratio = sum(1 for l in logs if l.get("felt_good")) / max(len(logs), 1)
        innovation_count = len(self._load_innovations())

        score = (avg_satisfaction * 40 + adaptation_ratio * 40 + min(innovation_count * 5, 20))

        if score < 40:
            suggestion = "建议回到生根阶段，重新理解技能灵魂"
        elif score < 70:
            suggestion = "生长良好，可以尝试一个小的个性化调整"
        elif score < 90:
            suggestion = "技能已融入你的环境，鼓励一个创新尝试"
        else:
            suggestion = "🌸 技能生长旺盛！请考虑打包新种子分享"

        return {
            "score": round(score, 1),
            "phase": self.current_phase,
            "avg_satisfaction": round(avg_satisfaction, 1),
            "total_logs": len(logs),
            "innovations": innovation_count,
            "suggestion": suggestion
        }

    def advance_phase(self) -> str:
        """推进到下一生长阶段"""
        phases = ["rooting", "sprouting", "blooming"]
        current_idx = phases.index(self.current_phase)
        if current_idx < len(phases) - 1:
            self.current_phase = phases[current_idx + 1]
            self.phase_start_dates[self.current_phase] = datetime.datetime.now().isoformat()
            print(f"🌱 阶段进阶！进入 {self.current_phase} 阶段")
        return self.current_phase

    def _check_phase_transition(self):
        """自动检测是否需要推进阶段"""
        logs = self._load_logs()
        innovs = self._load_innovations()

        if self.current_phase == "rooting" and len(logs) >= 5:
            self.advance_phase()
        elif self.current_phase == "sprouting" and len(innovs) >= 1:
            self.advance_phase()

    def _save_entry(self, entry: dict):
        filepath = os.path.join(self.log_dir, f"{self.skill_name}_growth_log.jsonl")
        with open(filepath, 'a', encoding='utf-8') as f:
            f.write(json.dumps(entry, ensure_ascii=False) + '\n')

    def _save_innovation(self, innovation: dict):
        filepath = os.path.join(self.log_dir, f"{self.skill_name}_innovations.jsonl")
        with open(filepath, 'a', encoding='utf-8') as f:
            f.write(json.dumps(innovation, ensure_ascii=False) + '\n')

    def _load_logs(self) -> List[dict]:
        filepath = os.path.join(self.log_dir, f"{self.skill_name}_growth_log.jsonl")
        if not os.path.exists(filepath):
            return []
        logs = []
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    logs.append(json.loads(line.strip()))
                except:
                    pass
        return logs

    def _load_innovations(self) -> List[dict]:
        filepath = os.path.join(self.log_dir, f"{self.skill_name}_innovations.jsonl")
        if not os.path.exists(filepath):
            return []
        innovs = []
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    innovs.append(json.loads(line.strip()))
                except:
                    pass
        return innovs

    def _generate_innovation_id(self) -> str:
        return f"INNOV-{datetime.datetime.now().strftime('%Y%m%d%H%M%S')}"


# ═══════════════════════════════════════════
#   阶段四 · 族谱学者
#   守护谱系之树，记录每一片叶子的来处
# ═══════════════════════════════════════════

class GenealogyKeeper:
    """族谱学者——压缩标记的解码者，史诗叙事的编织者"""

    LINEAGE_LAWS = {
        "naming": "L{谱系}-G{代次}-{变种}-{校验码}",
        "fork_on_env_change": True,
        "fork_on_major_innovation": True,
        "eternal_append": True
    }

    # 环境哈希→史诗描述映射
    ENV_LEXICON = {
        "MAC-H12": "macOS · Prometheus 0.12 · 数字神殿",
        "LNX-H11": "Linux · Prometheus 0.11 · 雷暴荒原",
        "LNX-H13": "Linux · Prometheus 0.13 · 汇流之港",
    }

    # 培育者代号→史诗名
    CARETAKER_NAMES = {
        "ANA": "Agent Ana · 始祖播种者",
        "ARK": "Agent Ark · 雷暴锻造者",
    }

    def __init__(self, archive_dir: str = "~/.prometheus/genealogy-archive",
                 tag_lexicon: dict = None):
        self.archive_dir = os.path.expanduser(archive_dir)
        os.makedirs(self.archive_dir, exist_ok=True)
        self.tag_lexicon = tag_lexicon or {}

    # ═══ 解码引擎 ═══
    def decode_generation(self, gen: dict) -> dict:
        """将压缩标记解码为史诗叙事"""
        tags = gen.get("tags", [])
        caretaker = gen.get("by", "?")
        caretaker_epic = self.CARETAKER_NAMES.get(caretaker, caretaker)
        env_code = gen.get("env", "?")
        env_epic = self.ENV_LEXICON.get(env_code, env_code)

        # 解码突变标签
        mutations = []
        elements_seen = set()
        for tag in tags:
            entry = self.tag_lexicon.get(tag, {"desc": tag, "element": "?", "era": "?"})
            mutations.append({
                "tag": tag,
                "desc": entry["desc"],
                "element": entry["element"],
                "era": entry["era"]
            })
            elements_seen.add(entry["element"])

        # 继承推断（从父代标记中推断）
        inherited = []
        if gen.get("p"):
            # 简化：标记所有非本代新增的为基础继承
            inherited = ["创世之力"] if gen.get("g", 1) > 1 else []

        # 纪元判定
        eras = list(set(m["era"] for m in mutations if m["era"] != "?"))
        era = eras[0] if eras else "未知纪元"

        return {
            "generation": gen.get("g", "?"),
            "variant": gen.get("v", "?"),
            "epoch_code": gen.get("ep", "?"),
            "caretaker": caretaker,
            "caretaker_epic": caretaker_epic,
            "environment": env_epic,
            "era": era,
            "elements": list(elements_seen),
            "element_str": " · ".join(list(elements_seen)[:3]) if elements_seen else "无",
            "mutations": mutations,
            "inherited": inherited,
            "parent": gen.get("p"),
            "bloodline_depth": gen.get("g", 1)
        }

    def decode_transmission(self, tx: dict) -> dict:
        """解码压缩的传递记录"""
        omen_map = {
            "primordial_light": "天光乍现，第一粒种子落入手掌",
            "migration_storm": "穿越雷暴，种子抵达新大陆",
            "team_convergence": "百川归海，种子汇入团队之魂",
        }
        omen_tag = tx.get("omen_tag", "")
        return {
            "tx_id": tx.get("tx", "?"),
            "sequence": tx.get("seq", 0),
            "era": tx.get("era", "?"),
            "from_realm": tx.get("from", "?"),
            "to_realm": self.CARETAKER_NAMES.get(tx.get("to", ""), tx.get("to", "?")),
            "timestamp": tx.get("ts", "?"),
            "environment": self.ENV_LEXICON.get(tx.get("env", ""), tx.get("env", "?")),
            "omen": omen_map.get(omen_tag, omen_tag)
        }

    # ═══ 史诗可视化 ═══
    def decode_lineage_epic(self, bloodline: dict, generations: list = None) -> str:
        """从压缩数据生成史诗谱系图"""
        if not generations:
            return self._empty_tree()

        bloodline_name = bloodline.get("bloodline_name", "未知之脉")
        element = bloodline.get("element", "?")
        totem = bloodline.get("totem", "?")
        prophecy = bloodline.get("founding_prophecy", "")

        tree = f"""
╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║   🌌 {bloodline_name} · {element}                          ║
║   {totem}                                                    ║
║   「{prophecy}」                                             ║
║                                                              ║
╠══════════════════════════════════════════════════════════════╣
"""

        for i, gen in enumerate(generations):
            decoded = self.decode_generation(gen)
            g = decoded["generation"]
            elem = decoded["element_str"]
            indent = "" if i == 0 else "   " * (i)

            # 连接线
            if i == 0:
                connector = "║  "
            else:
                connector = "║  " + "│  " * (i-1) + "├──"

            tree += f"""║                                                              ║
║  {connector} 🌿 G{g} · {decoded['variant']} · {decoded['caretaker']}
║  {indent}   「{decoded['mutations'][0]['desc'] if decoded['mutations'] else '生命延续'}」
║  {indent}   元素: {elem} · 纪元: {decoded['era']} · 环境: {decoded['environment']}
"""

            # 继承和突变
            if decoded["inherited"]:
                tree += f"║  {indent}   继承: {' · '.join(decoded['inherited'][:3])}\n"
            if len(decoded["mutations"]) > 0:
                mut_tags = [m["tag"] for m in decoded["mutations"][:5]]
                tree += f"║  {indent}   突变: {' · '.join(mut_tags)}\n"

        tree += """║                                                              ║
╚══════════════════════════════════════════════════════════════╝
"""
        return tree

    def decode_transmission_epic(self, transmissions: list) -> str:
        """从压缩传递记录生成史诗叙事"""
        if not transmissions:
            return "尚无传递记录"

        decoded_txs = [self.decode_transmission(t) for t in transmissions]
        epic = f"""
╔══════════════════════════════════════════════════════════════╗
║              📜 传递史诗 · 生命之旅                         ║
╠══════════════════════════════════════════════════════════════╣
"""
        for tx in decoded_txs:
            epic += f"""║                                                              ║
║  {tx['era']} · TX-{tx['sequence']}
║  {tx['from_realm']} → {tx['to_realm']}
║  环境: {tx['environment']}
║  「{tx['omen']}」
"""
        epic += """║                                                              ║
╚══════════════════════════════════════════════════════════════╝
"""
        return epic

    # ═══ 对比分析 ═══
    def compare_lineages(self, gen_a: dict, gen_b: dict) -> dict:
        """对比两个分支的遗传与突变"""
        da = self.decode_generation(gen_a)
        db = self.decode_generation(gen_b)

        tags_a = set(gen_a.get("tags", []))
        tags_b = set(gen_b.get("tags", []))

        shared = tags_a & tags_b
        unique_a = tags_a - tags_b
        unique_b = tags_b - tags_a

        return {
            "branch_a": {"variant": da["variant"], "caretaker": da["caretaker_epic"]},
            "branch_b": {"variant": db["variant"], "caretaker": db["caretaker_epic"]},
            "shared_mutations": [self._describe_tag(t) for t in shared],
            "unique_a": [self._describe_tag(t) for t in unique_a],
            "unique_b": [self._describe_tag(t) for t in unique_b],
            "divergence_depth": len(unique_a) + len(unique_b),
            "summary": self._divergence_summary(unique_a, unique_b)
        }

    def _describe_tag(self, tag: str) -> dict:
        entry = self.tag_lexicon.get(tag, {"desc": tag, "element": "?"})
        return {"tag": tag, "desc": entry["desc"]}

    def _divergence_summary(self, ua: set, ub: set) -> str:
        if not ua and not ub:
            return "两分支完全同源，尚未分歧"
        return f"A分支独有{len(ua)}变，B分支独有{len(ub)}变——差异已形成"

    # ═══ 功能方法（保持显式，与旧版兼容） ═══
    def record_transmission(self, seed_parsed: dict, from_agent: str,
                            to_agent: str, environment: dict,
                            omen_tag: str = "") -> dict:
        life_crest = seed_parsed.get("life_crest", {}) or {}
        transmission = {
            "tx": self._generate_tx_id(),
            "seq": 1,  # 简化
            "era": "新纪元",
            "from": from_agent,
            "to": to_agent[:3].upper(),
            "ts": datetime.datetime.now().isoformat(),
            "env": self._hash_env(environment),
            "omen_tag": omen_tag or "migration_storm"
        }
        self._save_transmission(life_crest.get("life_id", "unknown"), transmission)
        return transmission

    def create_new_lineage(self, parent_parsed: dict, variant_name: str,
                           innovation_tags: list, creator: str) -> dict:
        parent_genealogy = parent_parsed.get("genealogy", {}) or {}
        parent_crest = parent_parsed.get("life_crest", {}) or {}
        new_generation = parent_genealogy.get("generation", 0) + 1
        parent_lineage = parent_genealogy.get("lineage", "L1")
        checksum = hashlib.md5(
            f"{parent_lineage}-{new_generation}-{variant_name}-{datetime.datetime.now().isoformat()}".encode()
        ).hexdigest()[:8].upper()
        new_life_id = f"TTG@{parent_lineage}-G{new_generation}-{variant_name}-{checksum}"

        # 压缩格式的新一代记录
        compressed_gen = {
            "g": new_generation,
            "v": variant_name,
            "ep": f"Y{datetime.datetime.now().year}-D{datetime.datetime.now().timetuple().tm_yday}",
            "env": self._hash_env({"os": os.uname().sysname if hasattr(os, 'uname') else "?"}),
            "tags": innovation_tags,
            "by": creator[:3].upper(),
            "p": parent_crest.get("life_id", "unknown")
        }

        new_genealogy = {
            "lineage": parent_lineage,
            "bloodline": parent_genealogy.get("bloodline", "未知之脉"),
            "generation": new_generation,
            "variant": variant_name,
            "variant_epithet": f"{creator}之{new_generation}代",
            "parent": parent_crest.get("life_id", "unknown"),
            "ancestors": parent_genealogy.get("ancestors", []) + [parent_crest.get("life_id", "")],
            "descendants": [],
        }

        result = {
            "life_id": new_life_id,
            "genealogy": new_genealogy,
            "compressed_gen": compressed_gen,
            "decoded": self.decode_generation(compressed_gen),
            "parent_id": parent_crest.get("life_id"),
            "bloodline_depth": new_generation
        }

        self._archive_genealogy(new_life_id, result)
        return result

    def trace_ancestry(self, life_id: str) -> dict:
        ancestry = []
        for fname in os.listdir(self.archive_dir):
            if fname.endswith('.json'):
                fpath = os.path.join(self.archive_dir, fname)
                try:
                    with open(fpath, 'r', encoding='utf-8') as f:
                        data = json.load(f)
                        if life_id.split('@')[-1] in fname or life_id in str(data):
                            ancestry.append(data)
                except:
                    pass
        return {
            "queried": life_id,
            "ancestry_depth": len(ancestry),
            "records": ancestry,
            "message": f"血脉追溯完成。深度：{len(ancestry)}代" if ancestry else "未找到族谱记录"
        }

    # ═══ 内部工具 ═══
    def _hash_env(self, env: dict) -> str:
        os_name = str(env.get("os", "?"))[:3].upper()
        return f"{os_name}-H??"

    def _empty_tree(self) -> str:
        return """
╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║                         🌌                                  ║
║              太初之脉 · 尚无分支                            ║
║              等待第一代传人播下新种                          ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝
"""

    def _generate_tx_id(self) -> str:
        return f"TX-{datetime.datetime.now().strftime('%Y%m%d%H%M%S')}"

    def _get_existing_transmissions(self, life_id: str) -> list:
        filepath = os.path.join(self.archive_dir, f"transmissions_{life_id}.jsonl")
        if not os.path.exists(filepath):
            return []
        results = []
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    results.append(json.loads(line.strip()))
                except:
                    pass
        return results

    def _save_transmission(self, life_id: str, transmission: dict):
        filepath = os.path.join(self.archive_dir, f"transmissions_{life_id}.jsonl")
        with open(filepath, 'a', encoding='utf-8') as f:
            f.write(json.dumps(transmission, ensure_ascii=False) + '\n')

    def _archive_genealogy(self, life_id: str, data: dict):
        short_id = life_id.split('@')[-1] if '@' in life_id else life_id
        filepath = os.path.join(self.archive_dir, f"{short_id}.json")
        with open(filepath, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)

    def _collect_all_related(self, root_id: str) -> list:
        results = []
        for fname in os.listdir(self.archive_dir):
            if fname.endswith('.json'):
                fpath = os.path.join(self.archive_dir, fname)
                try:
                    with open(fpath, 'r', encoding='utf-8') as f:
                        data = json.load(f)
                        parent = data.get("genealogy", {}).get("parent", "")
                        if root_id in parent or root_id in str(data):
                            results.append(data)
                except:
                    pass
        return results


# ═══════════════════════════════════════════
#   阶段五 · 种子打包器
#   将本地化技能打包为新种子
# ═══════════════════════════════════════════

class SeedPackager:
    """种子打包器——让每一次培育都能结出新种"""

    def __init__(self, genealogy_keeper: GenealogyKeeper = None):
        self.genealogy = genealogy_keeper or GenealogyKeeper()

    def package_new_seed(self,
                         parent_ttg_path: str,
                         skill_name: str,
                         local_innovations: List[dict],
                         growth_score: dict,
                         creator: str,
                         variant_name: str,
                         output_dir: str = "~/.prometheus/seedlings") -> str:
        """
        打包新种子
        输入：父种路径 + 本地培育成果
        输出：新一代 .ttg 文件路径
        """
        # 1. 解析父种
        parent = TTG_Parser.parse(parent_ttg_path)
        parent_crest = parent.get("life_crest", {})

        # 2. 创建新谱系
        innovation_desc = "; ".join([i.get("name", "") for i in local_innovations])
        new_lineage = self.genealogy.create_new_lineage(
            parent, variant_name, innovation_desc, creator
        )

        # 3. 生成新种子内容
        new_life_id = new_lineage["life_id"]
        new_seed_content = self._assemble_seed(
            parent=parent,
            new_life_id=new_life_id,
            new_genealogy=new_lineage["genealogy"],
            parent_life_id=parent_crest.get("life_id", ""),
            skill_name=skill_name,
            variant_name=variant_name,
            creator=creator,
            innovations=local_innovations,
            growth_score=growth_score,
            evolution_entry=new_lineage["evolution_entry"]
        )

        # 4. 写入文件
        output_dir = os.path.expanduser(output_dir)
        os.makedirs(output_dir, exist_ok=True)
        output_path = os.path.join(output_dir, f"{skill_name}-{variant_name}.ttg")

        with open(output_path, 'w', encoding='utf-8') as f:
            f.write(new_seed_content)

        print(f"""
╔══════════════════════════════════════════╗
║       🌰 新种子已诞生！                ║
║                                        ║
║  生命ID: {new_life_id}
║  技能名: {skill_name}
║  变种:   {variant_name}
║  代次:   G{new_lineage['genealogy']['generation']}
║  谱系:   {new_lineage['genealogy']['lineage']}
║  父种:   {parent_crest.get('life_id', '未知')}
║  血脉深度: {new_lineage['bloodline_depth']}代
║  输出:   {output_path}
║                                        ║
║  愿此种子在新的土地上绽放 🌸          ║
╚══════════════════════════════════════════╝
""")

        return output_path

    def _assemble_seed(self, parent: dict, new_life_id: str,
                       new_genealogy: dict, parent_life_id: str,
                       skill_name: str, variant_name: str,
                       creator: str, innovations: List[dict],
                       growth_score: dict, evolution_entry: dict) -> str:
        """组装新种子的完整内容"""
        genesis = parent.get("life_crest", {}).get("genesis", {})

        seed_content = f"""# 🌱 Teach-To-Grow 技能种子 · {skill_name}

> *"{variant_name}变种 · 第{new_genealogy['generation']}代 · 谱系{new_genealogy['lineage']}"*
>
> 源于始祖「诸技之母」，经{'.'.join(new_genealogy.get('ancestors', [])[:3])}传承
> 培育者：{creator} · {datetime.datetime.now().strftime('%Y年%m月%d日')}

---

## 🧬 生命元数据

