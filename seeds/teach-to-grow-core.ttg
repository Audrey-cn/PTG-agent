life_crest:
  life_id: "{new_life_id}"
  sacred_name: "{skill_name}"
  vernacular_name: "{skill_name}-{variant_name}"
  epithet: "源于{parent_life_id}的第{new_genealogy['generation']}代后裔"

  genesis:
    original_creator: "{genesis.get('creator', {}).get('name', '未知') if isinstance(genesis, dict) else '未知'}"
    original_purpose: "{genesis.get('purpose', '未知') if isinstance(genesis, dict) else '未知'}"
    variant_creator: "{creator}"
    variant_purpose: "{evolution_entry.get('description', '本地化适应')}"

